{
  "name": "@dualabs-dev/ui-kit-docs",
  "version": "0.1.0",
  "description": "Dualabs docs sites layer — Vite source plugin + React components for docs.<product>.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dualabs-dev/ui-kit-docs.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "default": "./dist/vite-plugin/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@scalar/api-reference-react": "^0.7.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0"
  },
  "peerDependencies": {
    "@dualabs-dev/ui-kit": "^0.1.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "~5.9.3"
  }
}
